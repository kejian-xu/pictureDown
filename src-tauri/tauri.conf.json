{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "picturedown",
  "version": "0.1.0",
  "identifier": "com.xukejian.picturedown",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "picturedown",
        "width": 1200,
        "height": 900,
        "maximized": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": {
        "default-src": ["'self'", "asset:"],
        "connect-src": [
          "'self'",
          "https://yande.re",
          "https://files.yande.re",
          "https://assets.yande.re"
        ],
        "img-src": [
          "'self'",
          "asset:",
          "https://yande.re",
          "https://files.yande.re",
          "https://assets.yande.re",
          "data:"
        ],
        "style-src": ["'self'", "'unsafe-inline'"],
        "script-src": ["'self'"],
        "font-src": ["'self'"]
      }
    },
    "withGlobalTauri": true
  },
  "plugins": {
    "http": {
      "allowlist": {
        "all": true,
        "request": true,
        "scope": [
          "https://yande.re/*",
          "https://files.yande.re/*"
        ]
      }
    },
    "fs": {
      "allowlist": {
        "scope": ["$DOWNLOAD/*"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}