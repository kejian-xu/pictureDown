{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "picturedown",
  "version": "0.1.0",
  "identifier": "com.xukejian.picturedown",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1430",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "picturedown",
        "width": 1200,
        "height": 900,
        "maximized": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": {
        "default-src": ["'self'", "asset:"],
        "connect-src": [
          "'self'",
          "https://yande.re",
          "https://files.yande.re",
          "https://assets.yande.re",
          "https://konachan.com",
          "https://konachan.net",
          "https://danbooru.donmai.us",
          "https://gelbooru.com",
          "https://rule34.xxx",
          "https://api.rule34.xxx"
        ],
        "img-src": [
          "'self'",
          "asset:",
          "http://asset.localhost",
          "https://yande.re",
          "https://files.yande.re",
          "https://assets.yande.re",
          "https://konachan.com",
          "https://konachan.net",
          "https://danbooru.donmai.us",
          "https://cdn.donmai.us",
          "https://gelbooru.com",
          "https://img3.gelbooru.com",
          "https://video-cdn3.gelbooru.com",
          "https://us.rule34.xxx",
          "https://api-cdn.rule34.xxx"
        ],
        "style-src": ["'self'", "'unsafe-inline'"],
        "script-src": ["'self'"],
        "font-src": ["'self'"]
      },
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    },
    "withGlobalTauri": true
  },
  "plugins": {
    "http": {
      "scope": [
        "https://yande.re/*",
        "https://files.yande.re/*",
        "https://konachan.net/*",
        "https://danbooru.donmai.us/*",
        "https://cdn.donmai.us/*",
        "https://gelbooru.com/*",
        "https://img3.gelbooru.com/*"
      ]
    },
    "fs": {
      "requireLiteralLeadingDot": false
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}