{
  "177comic": {
    "main_url": "https://www.177pica.com",
    "protocol_prefix": "https:",
    "home": {
      "catgory": [
        {
          "url": "/html/category/tt/",
          "title": "中文成人H漫画(Chinese)"
        },{
           "url": "/html/category/jj/",
          "title": "日文成人H漫画(Chinese)"
        }
      ],
      "url": "/",
      "title": "首页",
      "detail_path_regex": "/html/(.+)\\.html$",
      "parseConfig": {
        "page": true,
        "item_selector": "figure.picture-img",
        "link_selector": "a",
        "img_selector": "img",
        "title_attr": "alt",
        "thumb_attr": "src",
        "link_attr": "href",
        "page_size_selector": ".nav-links .page-numbers",
        "page_size_url": "page/{num}/"
      }
    },
    "detail": {
      "title": "详情页",
      "url": "/html/{detailPath}.html",
      "extract_method": "css",
      "parseConfig": {
        "page": true,
        "img_selector": ".single-content img",
        "src_attrs": ["data-lazy-src", "src"],
        "page_size_selector": ".page-links a",
        "deduplicate": true
      }
    }
  },
  "wnacg": {
    "main_url": "https://www.wn07.cfd",
    "protocol_prefix": "https:",
    "home": {
      "url": "/",
       "title": "首页",
      "detail_path_regex": "/photos-index-aid-(\\d+)\\.html$",
      "parseConfig": {
        "item_selector": ".gallary_item",
        "link_selector": "a",
        "img_selector": "img",
        "title_attr": "alt",
        "thumb_attr": "src",
        "link_attr": "href"
      }
    },
    "detail": {
      "url": "/photos-item-aid-{detailPath}.html",
      "title": "详情页",
      "extract_method": "string",
      "parseConfig": {
        "page": false,
        "img_selector": ".pic_box a img",
        "src_attrs": ["src"],
        "page_size_selector": ".paginator span a",
        "deduplicate": true
      }
    }
  }
}